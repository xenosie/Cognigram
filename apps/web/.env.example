# API base URL for the cognigram-server backend.
VITE_API_URL=http://localhost:3001

# Google OAuth client ID — must be the SAME value as GOOGLE_CLIENT_ID in
# apps/server/.env so the server can verify tokens issued for this client.
# Create one at Google Cloud Console → Credentials → OAuth 2.0 Client IDs.
# Authorized JavaScript origins must include http://localhost:5173 (and any
# other origin you serve the SPA from).
VITE_GOOGLE_CLIENT_ID=replace-with-your-google-oauth-client-id.apps.googleusercontent.com
