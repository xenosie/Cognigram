# --- Network ---
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
CORS_ORIGINS=http://localhost:5173

# --- Storage ---
# Path to the embedded redb file. Created on first boot.
DB_PATH=./cognigram.redb

# --- Auth (Google OAuth) ---
# From Google Cloud Console → Credentials → OAuth 2.0 Client IDs.
# Use the SAME value for the web client (VITE_GOOGLE_CLIENT_ID in apps/web/.env).
GOOGLE_CLIENT_ID=replace-with-your-google-oauth-client-id.apps.googleusercontent.com

# Restrict sign-in to @gmail.com addresses. Set to false to allow any Google account.
GMAIL_ONLY=true

# --- JWT (our own access/refresh tokens) ---
# 32+ random bytes. Generate with: openssl rand -hex 48
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_SECS=2592000

# --- Misc ---
APP_NAME=Cognigram
LOG_LEVEL=info
